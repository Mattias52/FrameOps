{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/manufacturing",
      "destination": "/sop-generator/manufacturing",
      "statusCode": 301
    },
    {
      "source": "/healthcare",
      "destination": "/sop-generator/healthcare",
      "statusCode": 301
    },
    {
      "source": "/training",
      "destination": "/sop-generator/onboarding",
      "statusCode": 301
    },
    {
      "source": "/creators",
      "destination": "/sop-generator/tutorial-creator",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/api-youtube/:path*",
      "destination": "https://frameops-production.up.railway.app/:path*"
    },
    {
      "source": "/sop-generator/:slug",
      "destination": "/api/seo/:slug"
    },
    {
      "source": "/skapa-manual/:slug",
      "destination": "/api/seo/:slug"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
